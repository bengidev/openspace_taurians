{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri-schema/main/schema.json",
  "productName": "OpenSpace Taurians",
  "version": "0.1.0",
  "identifier": "com.openspace.taurians",
  "build": {
    "frontendDist": "../interfaces/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix interfaces run dev",
    "beforeBuildCommand": "npm --prefix interfaces run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSpace Taurians",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
